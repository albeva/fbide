<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<!--
  Autogenerated by cmake at configure time. Source: configured_files/app.manifest.in.
  @FBIDE_MANIFEST_ARCH@ is substituted with 'amd64' on 64-bit builds
  and 'x86' on 32-bit builds so the assembly identity and the
  Microsoft.Windows.Common-Controls dependency match the binary.
-->
<assembly xmlns="urn:schemas-microsoft-com:asm.v1" manifestVersion="1.0">
  <assemblyIdentity
    version="1.0.0.0"
    processorArchitecture="@FBIDE_MANIFEST_ARCH@"
    name="fbide"
    type="win32"
  />

  <!-- Enable visual styles (ComCtl32 v6) - required by wxWidgets -->
  <dependency>
    <dependentAssembly>
      <assemblyIdentity
        type="win32"
        name="Microsoft.Windows.Common-Controls"
        version="6.0.0.0"
        processorArchitecture="@FBIDE_MANIFEST_ARCH@"
        publicKeyToken="6595b64144ccf1df"
        language="*"
      />
    </dependentAssembly>
  </dependency>

  <!-- DPI awareness -->
  <application xmlns="urn:schemas-microsoft-com:asm.v3">
    <windowsSettings>
      <dpiAware xmlns="http://schemas.microsoft.com/SMI/2005/WindowsSettings">true/PM</dpiAware>
      <dpiAwareness xmlns="http://schemas.microsoft.com/SMI/2016/WindowsSettings">PerMonitorV2, PerMonitor</dpiAwareness>
    </windowsSettings>
  </application>
</assembly>
