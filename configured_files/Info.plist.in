<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple Computer//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  This file is autogenerated by cmake at configure time.
  Source template: configured_files/Info.plist.in
-->
<plist version="1.0">
<dict>
    <key>CFBundleIdentifier</key>
    <string>net.freebasic.fbide</string>
    <key>CFBundleName</key>
    <string>FBIde</string>
    <key>CFBundleDisplayName</key>
    <string>FBIde</string>
    <key>CFBundleExecutable</key>
    <string>fbide</string>
    <!-- Icon basename (Finder appends .icns). The file fbide.icns lives
         in the bundle's Resources/ — copied in by src/CMakeLists.txt. -->
    <key>CFBundleIconFile</key>
    <string>fbide</string>
    <!-- Marketing version, shown in Finder's Get Info. Three-dot semver. -->
    <key>CFBundleShortVersionString</key>
    <string>@PROJECT_VERSION@</string>
    <!-- Build / internal version. Carries the tag-tweak suffix so RC and
         beta builds sort distinctly from the final release. -->
    <key>CFBundleVersion</key>
    <string>@FBIDE_FULL_VERSION@</string>
    <key>CFBundleDevelopmentRegion</key>
    <string>English</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleSignature</key>
    <string>????</string>
    <key>NSPrincipalClass</key>
    <string>NSApplication</string>
    <key>NSHighResolutionCapable</key>
    <true/>
    <key>NSHumanReadableCopyright</key>
    <string>Copyright (c) 2026 Albert Varaksin. MIT License.</string>
    <!-- Floor matches CI's CMAKE_OSX_DEPLOYMENT_TARGET. Big Sur was
         the first macOS to ship Apple Silicon; below that we'd run
         into Xcode's own deployment-target floor and start needing
         conditional libc++ availability shims for the C++23 stdlib
         features we use. -->
    <key>LSMinimumSystemVersion</key>
    <string>11.0</string>
    <key>LSApplicationCategoryType</key>
    <string>public.app-category.developer-tools</string>
    <!-- Two document types declared:
           1. FreeBASIC source — .bas (program), .bi (header). Role
              `Editor` because the user authors / edits these.
           2. FBIde session — .fbs. Role `Owner` because the format is
              FBIde's own (machine-managed workspace state, not
              hand-edited prose). `Owner` tells Launch Services that
              FBIde is the canonical creator of this type.
         Both register at `LSHandlerRank=Default`, which claims FBIde
         as the system handler unless the user has already chosen a
         different default. Splitting the two types lets each get its
         own icon later (currently both reuse fbide.icns). -->
    <key>CFBundleDocumentTypes</key>
    <array>
        <dict>
            <key>CFBundleTypeName</key>
            <string>FreeBASIC source file</string>
            <key>CFBundleTypeExtensions</key>
            <array>
                <string>bas</string>
                <string>bi</string>
            </array>
            <key>CFBundleTypeRole</key>
            <string>Editor</string>
            <key>LSHandlerRank</key>
            <string>Default</string>
            <key>CFBundleTypeIconFile</key>
            <string>fbide</string>
        </dict>
        <dict>
            <key>CFBundleTypeName</key>
            <string>FBIde session</string>
            <key>CFBundleTypeExtensions</key>
            <array>
                <string>fbs</string>
            </array>
            <key>CFBundleTypeRole</key>
            <string>Owner</string>
            <key>LSHandlerRank</key>
            <string>Owner</string>
            <key>CFBundleTypeIconFile</key>
            <string>fbide</string>
        </dict>
    </array>
</dict>
</plist>
